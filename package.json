{
  "scripts": {
    "base": "git pull && yarn",
    "dev": "yarn base && concurrently \"yarn dev:frontend\" \"yarn dev:backend\"",
    "format": "yarn base && concurrently \"yarn format:frontend\" \"yarn format:backend\"",
    "dev:frontend": "cd frontend && yarn && yarn dev",
    "dev:backend": "cd backend && yarn && yarn dev",
    "format:frontend": "cd frontend && yarn format",
    "format:backend": "cd backend && yarn format"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}